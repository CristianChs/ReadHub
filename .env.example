# Supabase — proyecto (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo para uso en servidor (migraciones, seed, scripts admin). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Sistema RAG (SOLO SERVIDOR — sin prefijo NEXT_PUBLIC_) -------------------
# Proveedor de embeddings (voyage-4, 1024 dimensiones). https://voyageai.com
VOYAGE_API_KEY=

# Modelo conversacional. Groq, vía API compatible con OpenAI. https://console.groq.com
GROQ_API_KEY=
# Opcional: modelo de Groq. Por defecto llama-3.3-70b-versatile.
GROQ_MODEL=

# --- Pruebas E2E (Playwright) — opcional -------------------------------------
# Solo para apuntar las pruebas a otra instancia o a otro usuario. Por defecto
# se usa http://localhost:3000 y el usuario sembrado por supabase/seed.sql.
E2E_BASE_URL=
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
